---
import Layout from '../../layouts/Layout.astro'
import { createSupabaseServerClient } from '../../lib/supabase'
import { calculateBalances, centsToDisplay } from '../../lib/balance'

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies)
const { data: { user } } = await supabase.auth.getUser()
if (!user) return Astro.redirect('/signin')

const groupId = Astro.params.id!

// Fetch group
const { data: group } = await supabase
  .from('groups')
  .select('id, name, archived, created_by')
  .eq('id', groupId)
  .single()

if (!group) return Astro.redirect('/dashboard')

// Verify membership
const { data: membership } = await supabase
  .from('group_members')
  .select('id')
  .eq('group_id', groupId)
  .eq('user_id', user.id)
  .single()

if (!membership) return Astro.redirect('/dashboard')

// Fetch members
const { data: members } = await supabase
  .from('group_members')
  .select('user_id, profiles(id, email)')
  .eq('group_id', groupId)

// Fetch expenses
const { data: expenses } = await supabase
  .from('expenses')
  .select('id, description, amount_cents, paid_by, created_at, profiles(email)')
  .eq('group_id', groupId)
  .order('created_at', { ascending: false })

// Fetch splits
const expenseIds = (expenses ?? []).map((e: any) => e.id)
const { data: splits } = expenseIds.length > 0
  ? await supabase.from('expense_splits').select('expense_id, user_id, amount_cents').in('expense_id', expenseIds)
  : { data: [] }

const balances = calculateBalances(expenses ?? [], splits ?? [])
const totalCents = (expenses ?? []).reduce((sum: number, e: any) => sum + e.amount_cents, 0)

type Member = { user_id: string; profiles: { id: string; email: string } }
const memberList = (members ?? []) as Member[]
---
<Layout title={group.name} user={user}>
  <main>
    <div class="group-page-header">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
        <div>
          <a href="/dashboard" style="color:var(--text-muted);font-size:0.8rem;">← Back to groups</a>
          <h1 class="group-page-title" style="margin-top:0.4rem;">{group.name}</h1>
          <div class="group-page-meta">
            {memberList.length} member{memberList.length !== 1 ? 's' : ''}
            <span style="margin:0 0.4rem;color:var(--text-muted);">·</span>
            <span id="group-total">Total spent: <strong>${centsToDisplay(totalCents)}</strong></span>
          </div>
        </div>
        <div style="display:flex;gap:0.5rem;align-items:center;margin-top:0.5rem;">
          <form method="POST" action={`/api/groups/${groupId}/archive`}>
            <input type="hidden" name="archived" value={group.archived ? 'false' : 'true'} />
            <button type="submit" class="btn btn-outline" style="font-size:0.75rem;">
              {group.archived ? 'Unarchive' : 'Archive'}
            </button>
          </form>
          <button
            class="btn btn-outline-green"
            x-data
            x-on:click="$dispatch('open-add-expense')"
          >
            + Add expense
          </button>
        </div>
      </div>
    </div>

    <div class="two-col">
      <!-- LEFT: Expenses -->
      <div>
        <h2 style="font-size:1rem;color:var(--text-muted);margin-bottom:1rem;text-transform:uppercase;letter-spacing:0.05em;">Expenses</h2>
        <div
          id="expenses-section"
        >
          <div id="expense-form-error"></div>
          <div id="expenses-list">
            {expenses && expenses.length > 0 ? (expenses as any[]).map((e: any) => (
              <div class="expense-item">
                <div>
                  <div class="expense-desc">{e.description}</div>
                  <div class="expense-meta">
                    Paid by {e.profiles?.email ?? 'Unknown'} · {new Date(e.created_at).toLocaleDateString()}
                  </div>
                </div>
                <div style="display:flex;align-items:center;gap:0.75rem;">
                  <div class="expense-amount">${centsToDisplay(e.amount_cents)}</div>
                  <form method="POST" action={`/api/expenses/${e.id}/delete`} style="margin:0;">
                    <button type="submit" class="btn-trash" title="Delete expense" onclick="event.preventDefault();if(confirm('Delete this expense?'))this.closest('form').submit()">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="3 6 5 6 21 6"></polyline>
                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                        <path d="M10 11v6"></path><path d="M14 11v6"></path>
                        <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
                      </svg>
                    </button>
                  </form>
                </div>
              </div>
            )) : (
              <p style="color:var(--text-muted);font-size:0.85rem;">No expenses yet.</p>
            )}
          </div>
        </div>
      </div>

      <!-- RIGHT: Members & Balances -->
      <div>
        <!-- Members -->
        <div class="card" style="margin-bottom:1rem;">
          <h2 style="font-size:0.85rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.75rem;">Members</h2>
          <div id="members-list">
            {memberList.map(m => (
              <span class="member-chip">
                {m.user_id === user.id ? `${m.profiles.email} (you)` : m.profiles.email}
              </span>
            ))}
          </div>
          <hr class="divider" />
          <!-- Invite form -->
          <div>
            <form
              hx-post={`/api/groups/${groupId}/invite`}
              hx-target="#members-list"
              hx-swap="outerHTML"
              hx-on::after-request="this.reset()"
              style="display:flex;gap:0.5rem;margin-top:0.75rem;"
            >
              <input
                type="email"
                name="email"
                placeholder="Invite by email"
                style="flex:1;font-size:0.8rem;"
              />
              <button type="submit" class="btn btn-outline-green" style="white-space:nowrap;font-size:0.75rem;">Invite</button>
            </form>
          </div>
        </div>

        <!-- Balances -->
        <div class="card">
          <h2 style="font-size:0.85rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.75rem;">Balances</h2>
          <div id="balances-section">
            {memberList.map(m => {
              const net = balances[m.user_id] ?? 0
              const label = m.user_id === user.id ? 'You' : m.profiles.email
              return (
                <div class="balance-item">
                  <span>{label}</span>
                  {net === 0
                    ? <span class="amount-settled">settled</span>
                    : net > 0
                      ? <span class="amount-owed">+${centsToDisplay(net)}</span>
                      : <span class="amount-owe">-${centsToDisplay(net)}</span>
                  }
                </div>
              )
            })}
            {memberList.length === 0 && <p style="color:var(--text-muted);font-size:0.85rem;">No balances yet.</p>}
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- Add Expense Modal -->
  <div
    x-data="{ open: false }"
    x-on:open-add-expense.window="open = true"
    x-show="open"
    x-cloak
    class="modal-backdrop"
    x-on:click.self="open = false"
  >
    <div class="modal">
      <h2 class="modal-title">Add expense</h2>
      <form
        hx-post={`/api/groups/${groupId}/expenses`}
        hx-target="#expenses-section"
        hx-swap="innerHTML"
        hx-on::after-request="if(event.detail.successful) { this.reset(); window.dispatchEvent(new CustomEvent('close-add-expense')) }"
        x-on:close-add-expense.window="open = false"
      >
        <div class="form-group">
          <label for="exp-desc">Description</label>
          <input id="exp-desc" name="description" type="text" required placeholder="e.g. Dinner at Rosa's" />
        </div>
        <div class="form-group">
          <label for="exp-amount">Amount ($)</label>
          <input id="exp-amount" name="amount" type="number" step="0.01" min="0.01" required placeholder="0.00" />
        </div>
        <div class="form-group">
          <label for="exp-paidby">Paid by</label>
          <select id="exp-paidby" name="paid_by">
            {memberList.map(m => (
              <option value={m.user_id} selected={m.user_id === user.id}>
                {m.user_id === user.id ? `${m.profiles.email} (you)` : m.profiles.email}
              </option>
            ))}
          </select>
        </div>
        <div class="form-group">
          <label>Split with</label>
          <div class="checkbox-group">
            {memberList.map(m => (
              <label class="checkbox-label">
                <input type="checkbox" name="split_with" value={m.user_id} checked />
                {m.user_id === user.id ? 'You' : m.profiles.email}
              </label>
            ))}
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline" x-on:click="open = false">Cancel</button>
          <button type="submit" class="btn btn-outline-green">Add</button>
        </div>
      </form>
    </div>
  </div>
</Layout>
